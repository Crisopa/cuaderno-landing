---
const appUrl = 'https://panel.crisopa.app'

const benefits = [
  {
    title: 'La IA que ya usas',
    description: 'Sin aprender una herramienta nueva. Controlas Crisopa desde ChatGPT o Claude, con la mejor interfaz de chat que existe.',
    icon: 'chat',
  },
  {
    title: 'Habla, no teclees',
    description: 'Una nota de voz al salir de la finca y la visita queda registrada. Sin volver al despacho, sin formularios.',
    icon: 'mic',
  },
  {
    title: 'Verificado contra el MAPA',
    description: 'Antes de crear un tratamiento, la IA consulta la ficha oficial del MAPA en directo y comprueba producto, dosis y plazos.',
    icon: 'shield',
  },
]

const iconPaths: Record<string, string> = {
  chat: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  mic: 'M19 11a7 7 0 01-14 0m7 7v4m-4 0h8M12 1a3 3 0 00-3 3v7a3 3 0 006 0V4a3 3 0 00-3-3z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
}
---

<section id="asistente-ia" class="relative py-16 sm:py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-white via-primary-50/40 to-white"></div>
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-primary-100/40 rounded-full blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto" data-animate>
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-semibold text-primary-800 shadow-sm border border-primary-200">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-gradient-to-r from-primary-500 to-primary-600"></span>
        </span>
        Lo que nadie más tiene
      </span>
      <h2 class="mt-6 text-2xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
        Olvídate de registrarlo todo a mano.
        <span class="block bg-gradient-to-r from-primary-700 via-primary-600 to-primary-800 bg-clip-text text-transparent">ChatGPT lo hace por ti.</span>
      </h2>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        Crisopa se conecta a <strong class="font-semibold text-gray-900">ChatGPT</strong> o <strong class="font-semibold text-gray-900">Claude</strong>. Le dices lo que has hecho o lo que quieres planificar, y él lee y escribe en Crisopa por ti. Cero curva de aprendizaje.
      </p>
    </div>

    <!-- Connection visual -->
    <div class="mt-12 sm:mt-16" data-animate>
      <div class="relative mx-auto max-w-3xl rounded-3xl border border-gray-100 bg-white/70 backdrop-blur-md shadow-xl shadow-gray-900/5 px-6 py-8 sm:px-10 sm:py-10">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
          <!-- ChatGPT -->
          <div class="flex flex-col items-center gap-3">
            <div class="flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-gray-900 text-white shadow-lg shadow-gray-900/20 ring-1 ring-gray-900/5">
              <svg class="w-8 h-8 sm:w-9 sm:h-9" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-600">ChatGPT</span>
          </div>

          <!-- Flujo hacia Crisopa -->
          <div class="flow-wire" aria-hidden="true">
            <span class="flow-dot"></span>
          </div>

          <!-- Crisopa (hub) -->
          <div class="flex flex-col items-center gap-3">
            <div class="relative">
              <span class="absolute -inset-4 rounded-full bg-primary-400/25 blur-2xl"></span>
              <div class="relative flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 rounded-[1.75rem] bg-gradient-to-br from-primary-600 to-primary-800 text-white shadow-xl shadow-primary-900/40 ring-1 ring-white/25">
                <svg class="w-11 h-11 sm:w-12 sm:h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11.264 2.205A4 4 0 0 0 6.42 4.211l-4 8a4 4 0 0 0 1.359 5.117l6 4a4 4 0 0 0 4.438 0l6-4a4 4 0 0 0 1.576-4.592l-2-6a4 4 0 0 0-2.53-2.53z" />
                  <path d="M11.99 22 14 12l7.822 3.184" />
                  <path d="M14 12 8.47 2.302" />
                </svg>
              </div>
            </div>
            <span class="text-sm font-bold text-primary-800">Crisopa</span>
          </div>

          <!-- Flujo hacia Crisopa -->
          <div class="flow-wire flow-wire--reverse" aria-hidden="true">
            <span class="flow-dot"></span>
          </div>

          <!-- Claude -->
          <div class="flex flex-col items-center gap-3">
            <div class="flex items-center justify-center w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-[#D97757] text-white shadow-lg shadow-[#D97757]/30 ring-1 ring-black/5">
              <svg class="w-8 h-8 sm:w-9 sm:h-9" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.3041 3.541h-3.6718l6.696 16.918H24Zm-10.6082 0L0 20.459h3.7442l1.3693-3.5527h7.0052l1.3693 3.5528h3.7442L10.5363 3.541Zm-.3712 10.2197 2.2914-5.9456 2.2914 5.9456Z" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-gray-600">Claude</span>
          </div>
        </div>
        <p class="mt-8 text-center text-sm text-gray-500">
          Lo conectas una vez. A funcionar.
        </p>
      </div>
    </div>

    <!-- Benefits -->
    <div class="mt-10 sm:mt-14 grid gap-6 sm:grid-cols-3" data-animate="stagger">
      {benefits.map((benefit) => (
        <div class="relative p-6 rounded-2xl bg-white border border-gray-100 shadow-lg shadow-gray-900/5">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-primary-100 text-primary-700 mb-4">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[benefit.icon]} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-gray-900">{benefit.title}</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 sm:mt-14 text-center" data-animate>
      <a
        href={`${appUrl}/register`}
        class="group inline-flex items-center justify-center rounded-2xl bg-primary-800 px-7 py-3.5 text-base font-semibold text-white shadow-xl shadow-primary-900/20 transition-all duration-300 hover:bg-primary-900 hover:-translate-y-0.5 hover:shadow-2xl"
      >
        Probar el copiloto gratis
        <svg class="ml-2 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  /* Conexión: una marca sólida recorre el cable hacia Crisopa */
  .flow-wire {
    position: relative;
    overflow: hidden;
    border-radius: 9999px;
    /* Móvil: cable vertical */
    width: 2px;
    height: 2.5rem;
    background: var(--color-primary-200);
  }

  .flow-dot {
    position: absolute;
    left: 0;
    top: -1rem;
    width: 2px;
    height: 1rem;
    border-radius: 9999px;
    background: var(--color-primary-600);
    animation: flow-y 2s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }

  .flow-wire--reverse .flow-dot {
    animation-direction: reverse;
  }

  @keyframes flow-y {
    from {
      top: -1rem;
    }
    to {
      top: 2.5rem;
    }
  }

  /* Escritorio: cable horizontal */
  @media (min-width: 640px) {
    .flow-wire {
      width: 4rem;
      height: 2px;
    }

    .flow-dot {
      top: 0;
      left: -1rem;
      width: 1rem;
      height: 2px;
      animation-name: flow-x;
    }

    @keyframes flow-x {
      from {
        left: -1rem;
      }
      to {
        left: 4rem;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-dot {
      display: none;
    }
  }
</style>
