---
import OrbitingConnectors from './react/OrbitingConnectors.tsx'

const calendlyUrl = 'https://calendly.com/demo-crisopa/30min'

const benefits = [
  {
    title: 'La IA que ya usas',
    description: 'Sin aprender una herramienta nueva. Controlas Crisopa desde ChatGPT o Claude, con la interfaz de chat que ya conoces.',
    icon: 'chat',
  },
  {
    title: 'Habla o escribe',
    description: 'Una nota de voz al salir de la finca o un mensaje desde el ordenador. Queda registrado sin formularios y sin volver al despacho.',
    icon: 'mic',
  },
  {
    title: 'Un motor agronómico de verdad',
    description: 'Detrás del chat no hay un cuaderno simple: tratamientos, abonado, riego, almacén, SIGPAC... Y, por supuesto, verificado contra el MAPA.',
    icon: 'shield',
  },
]

const iconPaths: Record<string, string> = {
  chat: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  mic: 'M19 11a7 7 0 01-14 0m7 7v4m-4 0h8M12 1a3 3 0 00-3 3v7a3 3 0 006 0V4a3 3 0 00-3-3z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
}
---

<section id="asistente-ia" class="relative py-16 sm:py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-white via-primary-50/40 to-white"></div>
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-primary-100/40 rounded-full blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto" data-animate>
      <span class="inline-block font-data text-xs font-medium uppercase tracking-[0.18em] text-primary-700">
        Lo que nadie más tiene<span class="eyebrow-caret"></span>
      </span>
      <h2 class="mt-6 text-2xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
        Antes era una tarde de oficina,
        <span class="block bg-gradient-to-r from-primary-700 via-primary-600 to-primary-800 bg-clip-text text-transparent">ahora es una conversación.</span>
      </h2>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        Crisopa se conecta a <strong class="font-semibold text-gray-900">ChatGPT</strong> o <strong class="font-semibold text-gray-900">Claude</strong>. Le dices lo que has hecho o lo que quieres planificar, y él lee, escribe y conecta tu cuaderno con el resto de tus herramientas. Sin aprender ninguna nueva.
      </p>
    </div>

    <!-- Connection visual: ecosistema orbitando Crisopa -->
    <div class="mt-12 sm:mt-16" data-animate>
      <div class="relative mx-auto max-w-3xl rounded-3xl border border-primary-100/80 bg-surface/70 backdrop-blur-md shadow-xl shadow-primary-900/5 px-4 py-10 sm:px-10 sm:py-12">
        <OrbitingConnectors />
      </div>
    </div>

    <!-- Benefits -->
    <div class="mt-10 sm:mt-14 grid gap-6 sm:grid-cols-3" data-animate="stagger">
      {benefits.map((benefit) => (
        <div class="card-glow group relative p-6 rounded-2xl bg-white border border-gray-100 shadow-lg shadow-gray-900/5">
          <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-primary-100 text-primary-700 mb-4 transition-transform duration-500 group-hover:scale-110">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[benefit.icon]} />
            </svg>
          </div>
          <h3 class="text-base font-semibold text-gray-900 transition-colors duration-300 group-hover:text-primary-800">{benefit.title}</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 sm:mt-14 text-center" data-animate>
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-press
        class="group relative inline-flex items-center justify-center gap-2 rounded-2xl bg-primary-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-600/25 overflow-hidden transition-[background-color,box-shadow] duration-300 hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-700/30"
      >
        <!-- Shine único y nítido -->
        <span class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent via-white/25 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
        <span class="relative">Reservar demo</span>
        <svg class="relative h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
