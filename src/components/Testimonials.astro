---
const testimonials = [
  {
    quote: 'Antes tardaba una mañana entera en poner al día el cuaderno. Ahora lo hago desde el móvil en el mismo campo, en dos minutos.',
    name: 'Miguel Ángel R.',
    role: 'Agricultor, Albacete',
    crop: 'Viñedo y cereal',
    initials: 'MA',
  },
  {
    quote: 'Gestiono 40 explotaciones y con Crisopa puedo revisar todo desde el despacho. Las inspecciones ya no me quitan el sueño.',
    name: 'Laura S.',
    role: 'Técnica asesora, Jaén',
    crop: 'Olivar',
    initials: 'LS',
  },
  {
    quote: 'Lo que más valoro es que está en español de verdad, no traducido. Se nota que entienden el campo.',
    name: 'Francisco J. M.',
    role: 'Agricultor, Badajoz',
    crop: 'Tomate y maíz',
    initials: 'FJ',
  },
]
---

<section class="relative py-16 sm:py-24 lg:py-28 overflow-hidden bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16" data-animate>
      <span class="inline-flex items-center rounded-full bg-white px-5 py-2 text-sm font-semibold text-primary-800 shadow-sm border border-primary-200">
        Testimonios
      </span>
      <h2 class="mt-6 font-display text-2xl sm:text-4xl lg:text-5xl font-bold text-gray-900">
        Lo que dicen nuestros usuarios
      </h2>
      <p class="mt-4 text-base sm:text-lg text-gray-500">
        Agricultores y técnicos que ya confían en Crisopa para su día a día.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid gap-6 sm:gap-8 md:grid-cols-3">
      {testimonials.map((t, i) => (
        <div
          class="relative p-6 sm:p-8 rounded-2xl bg-gray-50 border border-gray-100"
          data-animate
          style={`transition-delay: ${i * 120}ms;`}
        >
          <!-- Quote icon -->
          <svg class="w-8 h-8 text-primary-200 mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
          </svg>

          <!-- Quote text -->
          <blockquote class="text-gray-700 leading-relaxed text-base">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary-700 flex items-center justify-center text-white text-sm font-bold">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">{t.name}</p>
              <p class="text-sm text-gray-500">{t.role}</p>
            </div>
          </div>

          <!-- Crop tag -->
          <div class="mt-4">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700 border border-primary-100">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 01-1.161.886l-.143.048a1.107 1.107 0 00-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 01-1.652.928l-.679-.906a1.125 1.125 0 00-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 00-8.862 12.872M12.75 3.031a9 9 0 016.69 14.036m0 0l-.177-.529A2.25 2.25 0 0017.128 15H16.5l-.324-.324a1.453 1.453 0 00-2.328.377l-.036.073a1.586 1.586 0 01-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438a2.25 2.25 0 01-1.228 2.446L10.5 21l-.652-.326" />
              </svg>
              {t.crop}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
