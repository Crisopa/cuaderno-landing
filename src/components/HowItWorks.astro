---
const steps = [
  {
    number: '01',
    title: 'Conecta tu IA',
    description: 'Enlazas Crisopa con ChatGPT o Claude. Se hace una vez, en un par de minutos, y listo.',
    icon: 'link',
  },
  {
    number: '02',
    title: 'Háblale o escríbele',
    description: 'Le dices lo que has hecho o lo que quieres planificar —por texto o nota de voz— y él lo registra en Crisopa.',
    icon: 'mic',
  },
  {
    number: '03',
    title: 'El cuaderno se cuadra solo',
    description: 'La IA verifica contra el MAPA y deja todo listo para la inspección. El cumplimiento llega solo, sin que tengas que pensar en ello.',
    icon: 'check-circle',
  },
]

const iconPaths: Record<string, string> = {
  'link': 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  'mic': 'M19 11a7 7 0 01-14 0m7 7v4m-4 0h8M12 1a3 3 0 00-3 3v7a3 3 0 006 0V4a3 3 0 00-3-3z',
  'check-circle': 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
}
---

<section id="como-funciona" class="relative py-16 sm:py-24 lg:py-32 bg-gradient-to-b from-surface-secondary to-background overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 right-0 w-72 h-72 bg-primary-100/40 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 w-64 h-64 bg-accent-100/40 rounded-full blur-3xl"></div>
    <!-- Subtle pattern -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(0,0,0,0.03)_1px,transparent_0)] bg-[size:32px_32px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto" data-animate>
      <span class="inline-block font-data text-xs font-medium uppercase tracking-[0.18em] text-primary-700">
        Cómo funciona<span class="eyebrow-caret"></span>
      </span>
      <h2 class="mt-6 font-display text-2xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        Empieza en minutos
      </h2>
      <p class="mt-6 text-lg text-foreground-muted leading-relaxed">
        Conéctala una vez y, a partir de ahí, trabajas conversando: por voz o por escrito.
      </p>
    </div>

    <!-- Steps -->
    <div class="mt-12 sm:mt-16">
      <div class="grid gap-6 lg:grid-cols-3 lg:gap-8 items-stretch">
        {steps.map((step, index) => (
          <div
            class="relative group h-full"
            data-animate
            style={`transition-delay: ${index * 120}ms;`}
          >
            <!-- Card -->
            <div class="card-glow relative h-full bg-surface rounded-3xl p-7 sm:p-8 shadow-lg shadow-gray-900/5 border border-primary-100/70">
              <!-- Icono + índice de paso -->
              <div class="flex items-center justify-between">
                <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary-600 to-primary-800 text-white shadow-lg shadow-primary-900/25 transition-transform duration-500 group-hover:scale-110">
                  <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[step.icon]} />
                  </svg>
                </div>
                <span class="font-data text-3xl font-semibold leading-none text-primary-200 transition-colors duration-300 group-hover:text-primary-300">
                  {step.number}
                </span>
              </div>

              <!-- Text -->
              <h3 class="mt-6 font-display text-xl font-bold text-foreground transition-colors duration-300 group-hover:text-primary-800">
                {step.title}
              </h3>
              <p class="mt-3 text-foreground-muted leading-relaxed">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA hint -->
    <div class="mt-16 text-center" data-animate>
      <p class="text-foreground-muted text-sm">
        Se conecta en menos de lo que tarda un café.
      </p>
    </div>
  </div>
</section>
