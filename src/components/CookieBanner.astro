<div
  id="cookie-banner"
  class="fixed bottom-4 left-4 right-4 sm:right-auto z-[100] w-auto sm:max-w-sm translate-y-[150%] opacity-0 transition-all duration-500 ease-out"
  role="dialog"
  aria-label="Aviso de cookies"
>
  <div class="rounded-2xl bg-gray-950 border border-gray-800/60 shadow-2xl shadow-black/30 p-4 sm:p-5 flex flex-col gap-3.5">
    <p class="text-sm text-gray-300 leading-relaxed">
      Usamos cookies técnicas y, con tu permiso, de análisis y marketing para medir el rendimiento del sitio.
      <a href="/cookies" class="text-primary-400 hover:text-primary-300 underline underline-offset-2 transition-colors">Más info</a>.
    </p>
    <div class="flex gap-2">
      <button
        id="cookie-reject"
        class="flex-1 rounded-lg bg-gray-800 px-4 py-2.5 text-sm font-semibold text-gray-200 hover:bg-gray-700 active:bg-gray-900 transition-colors cursor-pointer"
      >
        Solo esenciales
      </button>
      <button
        id="cookie-accept"
        class="flex-1 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-500 active:bg-primary-700 transition-colors cursor-pointer"
      >
        Aceptar
      </button>
    </div>
  </div>
</div>

<script>
  declare global {
    interface Window {
      gtag?: (...args: unknown[]) => void
    }
  }

  function updateConsent(granted: boolean) {
    if (typeof window.gtag === 'function') {
      window.gtag('consent', 'update', {
        ad_storage: granted ? 'granted' : 'denied',
        ad_user_data: granted ? 'granted' : 'denied',
        ad_personalization: granted ? 'granted' : 'denied',
        analytics_storage: granted ? 'granted' : 'denied',
      })
    }
  }

  function initCookieBanner() {
    const banner = document.getElementById('cookie-banner')
    const acceptBtn = document.getElementById('cookie-accept')
    const rejectBtn = document.getElementById('cookie-reject')
    if (!banner || !acceptBtn || !rejectBtn) return

    if (localStorage.getItem('cookie_consent')) {
      banner.remove()
      return
    }

    setTimeout(() => {
      banner.classList.remove('translate-y-[150%]', 'opacity-0')
      banner.classList.add('translate-y-0', 'opacity-100')
    }, 1500)

    function dismissBanner() {
      banner!.classList.remove('translate-y-0', 'opacity-100')
      banner!.classList.add('translate-y-[150%]', 'opacity-0')
      banner!.addEventListener('transitionend', () => banner!.remove(), { once: true })
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('cookie_consent', 'accepted')
      updateConsent(true)
      dismissBanner()
    })

    rejectBtn.addEventListener('click', () => {
      localStorage.setItem('cookie_consent', 'rejected')
      updateConsent(false)
      dismissBanner()
    })
  }

  initCookieBanner()
  document.addEventListener('astro:page-load', initCookieBanner)
</script>
