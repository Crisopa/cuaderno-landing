---
const casos = [
  {
    quote: 'Acabo de aplicar azufre en la parcela 3 contra el oídio.',
    context: 'Por nota de voz, al salir de la finca',
    result: 'Registra la visita y el tratamiento, y deja la tarea de seguimiento programada. Sin pasar por la oficina.',
    icon: 'mic',
  },
  {
    quote: 'Planifícame la campaña del tomate de esta parcela.',
    context: 'Una conversación de 5 minutos',
    result: 'Genera tratamientos, labores, riegos y abonado en sus fechas, tras un par de preguntas sobre el cultivo.',
    icon: 'calendar',
  },
  {
    quote: 'Hazme el plan de abonado de la finca de Juan.',
    context: 'Con criterio agronómico, no a ciegas',
    result: 'Consulta el histórico de abonado, pregunta para afinar y cruza recomendaciones fiables antes de generarlo.',
    icon: 'beaker',
  },
  {
    quote: '¿Con qué puedo tratar esta plaga? Créame el tratamiento.',
    context: 'Verificado contra la fuente oficial',
    result: 'Consulta la ficha del MAPA en directo, comprueba que el producto está autorizado, la dosis y el plazo, y lo registra.',
    icon: 'shield-check',
  },
]

const iconPaths: Record<string, string> = {
  mic: 'M19 11a7 7 0 01-14 0m7 7v4m-4 0h8M12 1a3 3 0 00-3 3v7a3 3 0 006 0V4a3 3 0 00-3-3z',
  calendar: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  beaker: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  'shield-check': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
}
---

<section id="casos" class="relative py-16 sm:py-24 lg:py-32 bg-background overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-primary-100/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-1/4 w-80 h-80 bg-accent-100/30 rounded-full blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto" data-animate>
      <span class="inline-block font-data text-xs font-medium uppercase tracking-[0.18em] text-primary-700">
        Casos de uso<span class="eyebrow-caret"></span>
      </span>
      <h2 class="mt-6 font-display text-2xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        Lo dices.
        <span class="text-primary-700">Está hecho.</span>
      </h2>
      <p class="mt-6 text-lg text-foreground-muted leading-relaxed">
        Le hablas como le hablarías a un compañero. El copiloto consulta, decide contigo y deja tu cuaderno cuadrado.
      </p>
    </div>

    <!-- Grid -->
    <div class="mt-12 sm:mt-16 grid gap-6 sm:grid-cols-2" data-animate="stagger">
      {casos.map((caso) => (
        <div class="card-glow group h-full flex flex-col rounded-2xl bg-surface p-6 sm:p-7 border border-primary-100/70 shadow-lg shadow-gray-900/5">
          <!-- Quote (lo que dice el asesor) -->
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 inline-flex h-9 w-9 items-center justify-center rounded-xl bg-primary-100 text-primary-700 transition-transform duration-500 group-hover:scale-110">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[caso.icon]} />
              </svg>
            </div>
            <div>
              <p class="text-base font-semibold text-foreground leading-snug">&ldquo;{caso.quote}&rdquo;</p>
              <p class="mt-1 text-xs font-medium text-foreground-muted">{caso.context}</p>
            </div>
          </div>

          <!-- Result (lo que hace el copiloto) -->
          <div class="mt-5 flex items-start gap-3 rounded-xl bg-primary-50/70 px-4 py-3">
            <svg class="flex-shrink-0 mt-0.5 h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <p class="text-sm text-foreground-muted leading-relaxed">{caso.result}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
