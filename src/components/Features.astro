---
const features = [
  {
    title: 'Copiloto agronómico',
    description: 'Conversa con tu explotación desde ChatGPT o Claude. Registra, planifica y recomienda por ti, con criterio sobre tu parcela.',
    icon: 'chat',
  },
  {
    title: 'Memoria agronómica',
    description: '¿Con qué tratamos esta plaga hace tres años? ¿Cuánto regamos? Recupera el histórico de cada parcela en lenguaje natural.',
    icon: 'memory',
  },
  {
    title: 'Diario de campo',
    description: 'Visitas estilo Notion y tareas por parcela y campaña. Captura sin fricción lo que pasa en campo, sin volver al despacho.',
    icon: 'document',
  },
  {
    title: 'Recomendación verificada',
    description: 'Productos cruzados con el registro del MAPA, usando la ficha oficial como fuente de verdad. Sin errores de dosis ni de autorización.',
    icon: 'shield',
  },
  {
    title: 'El motor técnico completo',
    description: 'Tratamientos, fertilización con UF de NPK, riego, parcelas SIGPAC, eco-regímenes PAC y almacén. Todo en un sitio.',
    icon: 'spray',
  },
  {
    title: 'El cuaderno se cuadra solo',
    description: 'El agente valida contra el MAPA y te avisa dónde no encaja. El cumplimiento del RD 1311/2012, como resultado, no como tarea.',
    icon: 'check',
  },
]

const iconPaths: Record<string, string> = {
  chat: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  memory: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  document: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  spray: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  check: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
}
---

<section id="caracteristicas" class="relative py-16 sm:py-24 lg:py-32 bg-white overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-100/30 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-100/30 rounded-full blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto" data-animate>
      <span class="inline-flex items-center rounded-full bg-white px-5 py-2 text-sm font-semibold text-primary-800 shadow-sm border border-primary-200">
        Qué incluye
      </span>
      <h2 class="mt-6 text-2xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
        Mucho más que un cuaderno.
        <span class="block text-primary-700">La herramienta del asesor.</span>
      </h2>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        El chat es solo el volante. El motor es Crisopa: guarda, estructura y valida cada tratamiento contra el MAPA. Todo lo que necesitas para llevar tus fincas, en un solo sitio.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="mt-12 sm:mt-20 grid gap-4 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, index) => (
        <div
          class="relative group h-full"
          data-animate
          style={`transition-delay: ${index * 100}ms;`}
        >
          <div class="relative h-full rounded-2xl bg-white p-5 sm:p-7 border border-gray-100 shadow-lg shadow-gray-900/5 transition-all duration-500 group-hover:shadow-xl group-hover:shadow-primary-900/10 group-hover:-translate-y-1">
            <!-- Gradient border on hover -->
            <div class="absolute -inset-px rounded-2xl bg-gradient-to-br from-primary-400 to-accent-400 opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
            <div class="absolute inset-0 rounded-2xl bg-white"></div>

            <!-- Icon -->
            <div class="relative mb-5">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary-100 text-primary-700 transition-all duration-500 group-hover:bg-primary-600 group-hover:text-white group-hover:scale-110">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[feature.icon]} />
                </svg>
              </div>
            </div>

            <!-- Text -->
            <h3 class="relative text-lg font-semibold text-gray-900 group-hover:text-primary-800 transition-colors duration-300">
              {feature.title}
            </h3>
            <p class="relative mt-3 text-sm text-gray-600 leading-relaxed">
              {feature.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
