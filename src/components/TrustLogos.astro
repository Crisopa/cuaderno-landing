---
// Logos de instituciones y certificaciones relevantes para el sector agrícola español
---

<section class="relative py-10 sm:py-14 bg-gray-50/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-gray-400 uppercase tracking-wider mb-8">
      Cumplimos con la normativa vigente
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-16 opacity-60 grayscale">
      <!-- MAPA (Ministerio de Agricultura) -->
      <div class="flex flex-col items-center gap-1.5 group" title="Ministerio de Agricultura, Pesca y Alimentación">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white border border-gray-200 flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
          </svg>
        </div>
        <span class="text-[10px] sm:text-xs text-gray-400 font-medium">MAPA</span>
      </div>

      <!-- RD 1311/2012 -->
      <div class="flex flex-col items-center gap-1.5 group" title="Real Decreto 1311/2012 de uso sostenible de fitosanitarios">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white border border-gray-200 flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <span class="text-[10px] sm:text-xs text-gray-400 font-medium">RD 1311/2012</span>
      </div>

      <!-- SIGPAC -->
      <div class="flex flex-col items-center gap-1.5 group" title="Integración con SIGPAC">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white border border-gray-200 flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
          </svg>
        </div>
        <span class="text-[10px] sm:text-xs text-gray-400 font-medium">SIGPAC</span>
      </div>

      <!-- PAC -->
      <div class="flex flex-col items-center gap-1.5 group" title="Compatible con la Política Agrícola Común">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white border border-gray-200 flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
        <span class="text-[10px] sm:text-xs text-gray-400 font-medium">PAC 2023-2027</span>
      </div>

      <!-- RGPD -->
      <div class="flex flex-col items-center gap-1.5 group" title="Cumplimiento RGPD - Datos alojados en la UE">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white border border-gray-200 flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <span class="text-[10px] sm:text-xs text-gray-400 font-medium">RGPD</span>
      </div>

      <!-- Eco-regímenes -->
      <div class="flex flex-col items-center gap-1.5 group" title="Soporte para eco-regímenes y condicionalidad reforzada">
        <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-white border border-gray-200 flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg class="w-7 h-7 sm:w-8 sm:h-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 01-1.161.886l-.143.048a1.107 1.107 0 00-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 01-1.652.928l-.679-.906a1.125 1.125 0 00-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 00-8.862 12.872M12.75 3.031a9 9 0 016.69 14.036m0 0l-.177-.529A2.25 2.25 0 0017.128 15H16.5l-.324-.324a1.453 1.453 0 00-2.328.377l-.036.073a1.586 1.586 0 01-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438a2.25 2.25 0 01-1.228 2.446L10.5 21l-.652-.326" />
          </svg>
        </div>
        <span class="text-[10px] sm:text-xs text-gray-400 font-medium">Eco-regímenes</span>
      </div>
    </div>
  </div>
</section>
