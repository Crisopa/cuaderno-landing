---
import HeroMockup from './HeroMockup.astro'

// Sección "Míralo en acción": muestra el producto en un marco de navegador.
//
// CÓMO AÑADIR EL VÍDEO DE SCREEN STUDIO:
//   1. Exporta el vídeo (mp4, ~1280px de ancho, sin audio) a public/demo.mp4
//      y un fotograma de portada a public/demo-poster.jpg.
//   2. Pon hasVideo = true. El <video> sustituye al mockup automáticamente.
const hasVideo = false
---

<section id="demo" class="relative overflow-hidden py-20 sm:py-28 bg-background">
  <!-- Glow esmeralda de fondo -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[820px] h-[420px] rounded-full bg-primary-200/30 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <!-- Encabezado -->
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <span class="inline-block font-data text-xs font-medium uppercase tracking-[0.18em] text-primary-700">
        Míralo en acción<span class="eyebrow-caret"></span>
      </span>
      <h2 class="mt-5 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl [text-wrap:balance]">
        El despacho, hecho desde el móvil
      </h2>
      <p class="mt-4 text-base sm:text-lg text-foreground-muted">
        Así de rápido se registra y se cuadra el cuaderno. Sin formularios interminables,
        sin volver a la oficina.
      </p>
    </div>

    <!-- Visual del producto -->
    <div class="relative mt-12 sm:mt-16" data-animate>
      <!-- Glow detrás del marco -->
      <div class="absolute -inset-4 sm:-inset-6 rounded-[2rem] bg-gradient-to-r from-primary-400/20 via-primary-300/10 to-accent-400/20 blur-2xl"></div>

      <div class="relative mx-auto max-w-4xl">
        {hasVideo ? (
          <div class="relative rounded-3xl bg-surface shadow-2xl overflow-hidden border border-primary-200/50 ring-1 ring-foreground/5">
            <!-- Barra de navegador -->
            <div class="h-10 bg-gradient-to-b from-gray-100 to-gray-50 border-b border-gray-200/70 flex items-center px-4">
              <div class="flex gap-[6px]">
                <span class="w-[10px] h-[10px] rounded-full bg-[#FF5F57]"></span>
                <span class="w-[10px] h-[10px] rounded-full bg-[#FEBC2E]"></span>
                <span class="w-[10px] h-[10px] rounded-full bg-[#28C840]"></span>
              </div>
              <div class="flex-1 mx-4">
                <div class="max-w-[200px] mx-auto h-5 bg-surface rounded-md border border-gray-200/60 flex items-center justify-center">
                  <span class="font-data text-[10px] text-gray-400">panel.crisopa.app</span>
                </div>
              </div>
            </div>
            <video
              class="w-full block"
              autoplay
              muted
              loop
              playsinline
              poster="/demo-poster.jpg"
            >
              <source src="/demo.mp4" type="video/mp4" />
            </video>
          </div>
        ) : (
          <HeroMockup />
        )}

        <!-- Badge flotante: verificado -->
        <div class="absolute -bottom-3 -left-3 sm:-bottom-6 sm:-left-6 z-20 animate-float" style="animation-delay: 0.5s;">
          <div class="w-14 h-14 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-700 shadow-xl shadow-primary-600/30 flex items-center justify-center rotate-3 hover:rotate-0 transition-transform duration-300">
            <svg class="h-7 w-7 sm:h-10 sm:w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        </div>

        <!-- Badge flotante: normativa -->
        <div class="absolute -top-3 -right-2 sm:-top-5 sm:-right-5 z-20 animate-float-delayed">
          <div class="flex items-center gap-2 rounded-xl bg-surface/90 backdrop-blur-md shadow-lg border border-primary-100 px-3 py-1.5 sm:px-4 sm:py-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-100">
              <svg class="w-4 h-4 text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </span>
            <span class="font-data text-xs sm:text-sm font-semibold text-foreground">RD 1311/2012</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
