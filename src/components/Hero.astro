---
import HeroMockup from './HeroMockup.astro'
const appUrl = 'https://panel.crisopa.app'
---

<section class="relative overflow-hidden bg-gradient-to-b from-primary-50/80 via-white to-white pt-28 pb-16 sm:pt-40 sm:pb-32 lg:min-h-screen flex items-center">
  <!-- Subtle background -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[600px] h-[600px] rounded-full bg-primary-100/40 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[400px] h-[400px] rounded-full bg-accent-100/30 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
    <div class="lg:grid lg:grid-cols-12 lg:gap-x-12 lg:gap-y-16 items-center">
      <!-- Contenido -->
      <div class="lg:col-span-6 flex flex-col justify-center">
        <!-- Badge -->
        <div class="mb-8" data-animate>
          <span class="inline-flex items-center gap-2.5 rounded-full bg-accent-50 px-5 py-2 text-sm font-medium text-accent-800 border border-accent-200">
            <span class="inline-flex rounded-full h-2.5 w-2.5 bg-accent-500"></span>
            Obligatorio a partir de 2026
          </span>
        </div>

        <!-- Headline -->
        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl xl:text-7xl" data-animate>
          Tu cuaderno de campo.
          <span class="block mt-2 text-primary-700">Siempre al día.</span>
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-base leading-relaxed text-gray-600 sm:mt-8 sm:text-xl max-w-xl" data-animate>
          Registra tratamientos y fertilización en minutos. Todo organizado, siempre a mano, listo para cualquier inspección.
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-col sm:flex-row gap-3 sm:gap-4" data-animate>
          <a
            href={`${appUrl}/register`}
            class="group relative inline-flex items-center justify-center rounded-2xl bg-primary-800 px-6 py-3.5 sm:px-8 sm:py-4 text-base font-semibold text-white shadow-xl shadow-primary-900/20 overflow-hidden transition-all duration-300 hover:shadow-2xl hover:shadow-primary-900/30 hover:-translate-y-1"
          >
            <span class="relative flex items-center gap-2">
              Prueba gratis
              <svg class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
          <a
            href="#como-funciona"
            class="group inline-flex items-center justify-center rounded-2xl border-2 border-gray-200 bg-white/80 backdrop-blur-sm px-6 py-3.5 sm:px-8 sm:py-4 text-base font-semibold text-gray-700 transition-all duration-300 hover:border-primary-300 hover:text-primary-800 hover:bg-primary-50/50 hover:shadow-lg"
          >
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400 group-hover:text-primary-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Ver cómo funciona
            </span>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="mt-8 sm:mt-12" data-animate>
          <div class="inline-flex flex-wrap items-center gap-3 sm:gap-4 rounded-2xl bg-gray-50 border border-gray-200 px-4 py-3 sm:px-6 sm:py-4">
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <div class="flex items-center justify-center w-6 h-6 rounded-full bg-primary-100">
                <svg class="h-3.5 w-3.5 text-primary-700" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="font-medium">30 días gratis</span>
            </div>
            <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <div class="flex items-center justify-center w-6 h-6 rounded-full bg-primary-100">
                <svg class="h-3.5 w-3.5 text-primary-700" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="font-medium">Sin tarjeta</span>
            </div>
            <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
            <div class="flex items-center gap-2 text-sm text-gray-600">
              <div class="flex items-center justify-center w-6 h-6 rounded-full bg-primary-100">
                <svg class="h-3.5 w-3.5 text-primary-700" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="font-medium">Válido para inspecciones</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Imagen/Mockup con efectos -->
      <div class="mt-12 sm:mt-16 lg:mt-0 lg:col-span-6" data-animate>
        <div class="relative mx-4 sm:mx-0">
          <HeroMockup />
        </div>
      </div>
    </div>
  </div>

</section>
