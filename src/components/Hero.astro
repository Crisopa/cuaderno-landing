---
import ShinyText from './react/ShinyText.tsx'
import ShapeGrid from './react/ShapeGrid.jsx'
const appUrl = 'https://panel.crisopa.app'
const calendlyUrl = 'https://calendly.com/demo-crisopa/30min'
---

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-44 sm:pb-28 lg:min-h-screen flex items-center">
  <!-- Fondo: crema + DotField interactivo esmeralda -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <!-- Tinte cálido superior (base para legibilidad del texto) -->
    <div class="absolute inset-0 bg-gradient-to-b from-primary-50/40 via-background/55 to-background/70"></div>
    <!-- Parcelario animado: cuadrícula en diagonal, el hover pinta una parcela -->
    <ShapeGrid
      client:idle
      shape="square"
      direction="diagonal"
      speed={0.4}
      squareSize={56}
      borderColor="rgba(16, 150, 120, 0.38)"
      hoverFillColor="rgba(16, 150, 120, 0.55)"
      hoverTrailAmount={5}
    />
    <!-- Desvanecido inferior: la cuadrícula se funde hacia el crema -->
    <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-b from-transparent to-background"></div>
  </div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 w-full text-center flex flex-col items-center">
    <!-- Badge -->
    <div class="mb-7 animate-fade-in-down" style="animation-delay: 100ms;">
      <span class="shine-hover inline-flex items-center gap-2.5 rounded-full border border-primary-200/70 bg-surface/90 px-4 py-1.5 text-sm font-medium text-primary-800 shadow-sm backdrop-blur-md">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-500 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-600"></span>
        </span>
        <ShinyText text="El único conectado a ChatGPT y Claude" speed={0.9} />
      </span>
    </div>

    <!-- Titular (Sora, sólido — sin degradado) -->
    <h1 class="font-display text-4xl font-extrabold tracking-tight text-foreground sm:text-6xl lg:text-7xl animate-fade-in-up [text-wrap:balance]" style="animation-delay: 200ms;">
      Tu copiloto agronómico
    </h1>

    <!-- Subtítulo -->
    <p class="mt-6 text-lg leading-relaxed text-foreground sm:text-2xl sm:leading-relaxed max-w-2xl animate-fade-in-up" style="animation-delay: 300ms;">
      El motor agronómico completo —tratamientos, abonado, riego, todas tus fincas— que manejas
      hablando con ChatGPT o Claude. <span class="font-semibold text-foreground">Todo tu campo bajo control, en tiempo récord.</span>
    </p>

    <!-- CTAs -->
    <div class="mt-9 flex flex-col sm:flex-row gap-3 sm:gap-4 animate-fade-in-up" style="animation-delay: 400ms;">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-press
        class="group relative inline-flex items-center justify-center gap-2 rounded-2xl bg-primary-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-600/25 overflow-hidden transition-[background-color,box-shadow] duration-300 hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-700/30"
      >
        <!-- Shine único y nítido -->
        <span class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent via-white/25 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
        <span class="relative">Reservar demo</span>
        <svg class="relative h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="#demo"
        data-press
        class="group inline-flex items-center justify-center gap-2 rounded-2xl border border-primary-200 bg-surface/90 backdrop-blur-md px-8 py-4 text-base font-semibold text-primary-800 transition-[color,background-color,border-color,box-shadow] duration-300 hover:border-primary-300 hover:bg-primary-50 hover:shadow-md"
      >
        <svg class="w-5 h-5 text-primary-500 transition-colors group-hover:text-primary-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Ver cómo funciona
      </a>
    </div>

    <!-- Enlace discreto a prueba self-serve -->
    <p class="mt-4 text-sm text-foreground-muted animate-fade-in-up" style="animation-delay: 450ms;">
      ¿Prefieres probarlo por tu cuenta?
      <a href={`${appUrl}/register`} class="font-medium text-primary-700 underline underline-offset-2 hover:text-primary-900 transition-colors">Empieza gratis</a>
    </p>

    <!-- Trust indicators (dato en mono) -->
    <div class="mt-10 animate-fade-in-up" style="animation-delay: 500ms;">
      <div class="inline-flex flex-wrap items-center justify-center gap-x-4 gap-y-2 rounded-2xl border border-primary-100 bg-surface/90 backdrop-blur-md px-5 py-3 shadow-sm">
        <span class="inline-flex items-center gap-2 text-sm text-foreground-muted">
          <svg class="h-4 w-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Demo en 30 min
        </span>
        <span class="w-px h-4 bg-primary-200 hidden sm:block"></span>
        <span class="inline-flex items-center gap-2 text-sm text-foreground-muted">
          <svg class="h-4 w-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Sin compromiso
        </span>
        <span class="w-px h-4 bg-primary-200 hidden sm:block"></span>
        <span class="inline-flex items-center gap-2 text-sm text-foreground-muted">
          <svg class="h-4 w-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
          Verificado contra el MAPA
        </span>
      </div>
    </div>
  </div>

  <!-- Indicador de scroll -->
  <a href="#demo" aria-label="Ver la demo" class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-soft hidden lg:flex flex-col items-center gap-2 text-foreground-muted hover:text-primary-700 transition-colors">
    <span class="text-xs font-medium uppercase tracking-wider">Ver más</span>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </a>
</section>
