---
const navLinks = [
  { href: '/#caracteristicas', label: 'Qué incluye', section: 'caracteristicas' },
  { href: '/precios', label: 'Precios', page: '/precios' },
  { href: '/#faq', label: 'Dudas', section: 'faq' },
]

const appUrl = 'https://panel.crisopa.app'
const calendlyUrl = 'https://calendly.com/demo-crisopa/30min'
---

<header
  id="header"
  class="fixed inset-x-0 top-0 z-50 transition-transform duration-500"
>
  <div class="mx-auto max-w-6xl px-4 pt-3 sm:px-6 sm:pt-4">
    <!-- Isla flotante con cristal -->
    <nav
      id="nav-bar"
      class="rounded-2xl border border-primary-100/50 bg-surface/55 px-3 shadow-lg shadow-primary-900/5 backdrop-blur-xl backdrop-saturate-150 transition-[background-color,box-shadow,border-color] duration-300 sm:px-4"
    >
    <div class="flex h-14 items-center justify-between">
      <!-- Logo -->
      <a href="/" data-press aria-label="Crisopa — inicio" class="group inline-flex items-center">
      <svg class="h-7" viewBox="0 0 510.42032 99.311523" xmlns="http://www.w3.org/2000/svg">
        <g transform="translate(-385.81631,-550.18079)">
          <!-- Texto -->
          <g class="text-foreground" fill="currentColor">
