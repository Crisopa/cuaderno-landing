---
const calendlyUrl = 'https://calendly.com/demo-crisopa/30min'
---

<section id="reservar-demo" class="relative py-16 sm:py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-background to-accent-50"></div>
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-100/40 rounded-full blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center" data-animate>
    <span class="inline-block font-data text-xs font-medium uppercase tracking-[0.18em] text-primary-700">
      Sin compromiso<span class="eyebrow-caret"></span>
    </span>

    <h2 class="mt-6 font-display text-2xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-foreground">
      Reserva una demo <span class="text-primary-700">personalizada</span>
    </h2>

    <p class="mt-4 text-lg text-foreground-muted leading-relaxed">
      Te enseñamos cómo Crisopa encaja en tu día a día en menos de 30 minutos.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        data-press
        class="group relative inline-flex items-center justify-center gap-2 rounded-2xl bg-primary-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-600/25 overflow-hidden transition-[background-color,box-shadow] duration-300 hover:bg-primary-700 hover:shadow-xl hover:shadow-primary-700/30"
      >
        <!-- Shine único y nítido -->
        <span class="pointer-events-none absolute inset-0 bg-gradient-to-r from-transparent via-white/25 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
        <span class="relative">Reservar demo</span>
        <svg class="relative h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <p class="mt-6 text-sm text-foreground-muted">Menos de 30 min &middot; Sin compromiso &middot; Online</p>
  </div>
</section>
