---
import Layout from '../layouts/Layout.astro'

const calendlyUrl = 'https://calendly.com/demo-crisopa/30min'
---

<Layout
  title="Demo para asesores agronómicos | Crisopa"
  description="Reserva una demo de 30 min y descubre cómo gestionar todas tus explotaciones en menos tiempo. Pensado para asesores que trabajan en volumen."
>
  <main class="min-h-screen flex flex-col">
