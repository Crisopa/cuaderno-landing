---
import Layout from '../layouts/Layout.astro'
import HeroMockup from '../components/HeroMockup.astro'

const calendlyUrl = 'https://calendly.com/demo-crisopa/30min'

const without = [
  'Horas registrando tratamientos uno a uno para cada agricultor',
  'Excel con cientos de filas que nadie quiere mantener',
  'Revisar manualmente dosis, productos y plazos de seguridad',
  'Cada explotación nueva multiplica el trabajo',
  'Software genérico que no entiende tu flujo de trabajo',
]

const withCrisopa = [
  'Registro en masa: un tratamiento, muchas explotaciones a la vez',
  'Todo organizado por explotación, parcela y campaña',
  'Validación automática con IA: productos, dosis, plazos',
  'De 10 a 200 explotaciones sin que cambie el esfuerzo',
  'Pensado desde el primer día para asesores GIP',
]

const features = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />',
    title: 'Registro en masa',
    description: 'Aplica un tratamiento a varias explotaciones a la vez. Lo que antes eran horas de copiar y pegar, ahora son minutos. Tú eliges las parcelas, Crisopa hace el resto.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />',
    title: 'Validación automática',
    description: 'Nuestro agente de IA comprueba que cada producto esté autorizado, que la dosis sea correcta y que se cumplan los plazos de seguridad. Lo mismo que harías a mano, pero sin el coste en tiempo.',
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />',
    title: 'Conforme al RD 1311/2012',
    description: 'Cuaderno de explotación, registro de tratamientos fitosanitarios, fertilización, parcelas SIGPAC. Todo lo que necesitas para pasar cualquier inspección sin sorpresas.',
  },
]
---

<Layout
  title="Demo para asesores agronómicos | Crisopa"
  description="Reserva una demo de 30 min y descubre cómo gestionar todas tus explotaciones en menos tiempo. Pensado para asesores que manejan decenas de explotaciones."
>
  <main>
    <!-- ==================== HERO ==================== -->
    <section class="relative overflow-hidden bg-gradient-to-b from-primary-50/80 via-white to-white pt-8 pb-16 sm:pt-12 sm:pb-24 lg:pb-32 lg:min-h-screen flex items-center">
      <!-- Animated background -->
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[700px] h-[700px] rounded-full bg-gradient-to-br from-primary-200/60 to-primary-100/40 blur-3xl animate-blob"></div>
        <div class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-tr from-accent-200/50 to-accent-100/30 blur-3xl animate-blob" style="animation-delay: 2s;"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-gradient-to-r from-primary-100/30 to-accent-100/20 blur-3xl animate-pulse-soft"></div>

        <div class="absolute top-20 left-[15%] w-3 h-3 rounded-full bg-primary-400/40 animate-float"></div>
        <div class="absolute top-40 right-[20%] w-2 h-2 rounded-full bg-accent-400/50 animate-float-delayed"></div>
        <div class="absolute bottom-32 left-[25%] w-4 h-4 rounded-full bg-primary-300/30 animate-float-slow"></div>
        <div class="absolute top-1/3 right-[10%] w-2.5 h-2.5 rounded-full bg-accent-300/40 animate-float" style="animation-delay: 1s;"></div>

        <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.02)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>
      </div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full">
        <!-- Logo -->
        <div class="mb-10 sm:mb-14">
          <svg class="h-7" viewBox="0 0 510.42032 99.311523" xmlns="http://www.w3.org/2000/svg">
            <g transform="translate(-385.81631,-550.18079)">
              <g class="text-gray-900" fill="currentColor">
                <path d="m 869.51978,630.4783 q -6.03135,0 -10.63149,-2.14674 -4.49796,-2.14675 -7.05361,-6.13356 -2.45343,-3.98683 -2.45343,-9.60925 0,-6.13356 2.96458,-10.01815 3.06676,-3.8846 8.48474,-5.82689 5.52023,-1.94229 12.88046,-1.94229 h 12.88053 v 8.48476 h -13.08497 q -4.90685,0 -7.56473,2.45342 -2.55565,2.3512 -2.55565,6.13356 0,3.78237 2.55565,6.13356 2.65788,2.3512 7.56473,2.3512 2.96458,0 5.41801,-1.02225 2.55565,-1.1245 4.19126,-3.68014 1.73783,-2.65787 1.94226,-7.15582 l 3.4757,3.98681 q -0.51111,5.82688 -2.86231,9.81369 -2.24898,3.98683 -6.33801,6.13357 -3.98681,2.04452 -9.81372,2.04452 z"/>
                <path d="m 884.99176,629.04713 v -16.45838 h -2.35121 V 594.2903 q 0,-4.80463 -2.3512,-7.15583 -2.35116,-2.3512 -7.25802,-2.3512 -2.55564,0 -6.13357,0.10227 -3.57792,0.10228 -7.25806,0.30668 -3.57792,0.10227 -6.44023,0.30668 v -12.06268 q 2.3512,-0.20444 5.31574,-0.40889 2.96459,-0.20446 6.03135,-0.20446 3.16903,-0.10228 5.92913,-0.10228 8.58699,0 14.20941,2.24897 5.72462,2.24897 8.58699,7.0536 2.96455,4.80461 2.96455,12.57379 v 34.45017 z"/>
