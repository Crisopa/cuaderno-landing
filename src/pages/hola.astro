    </div>

    <!-- Hero -->
    <section class="flex-1 flex items-center">
      <div class="relative w-full py-16 sm:py-24 lg:py-32 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-accent-50"></div>
        <div class="absolute inset-0 -z-10">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-100/40 rounded-full blur-3xl"></div>
        </div>

        <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center" data-animate>
          <span class="inline-flex items-center rounded-full bg-primary-100 px-4 py-1.5 text-sm font-semibold text-primary-800">
            Para asesores agronómicos
          </span>

          <h1 id="headline" class="mt-8 text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-gray-900 leading-tight">
            Registra tratamientos de todas tus explotaciones <span id="headline-accent" class="text-primary-700">sin perder la cabeza</span>
          </h1>

          <p id="subtitle" class="mt-6 text-lg sm:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto">
            Crisopa es el cuaderno de campo pensado para asesores que gestionan muchas explotaciones. Registro en masa, validación automática, cero horas perdidas.
          </p>

          <!-- Bullets -->
          <ul class="mt-10 space-y-4 text-left max-w-lg mx-auto" data-animate="stagger">
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700"><strong class="text-gray-900">Registro de tratamientos en masa</strong> — no uno a uno</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700"><strong class="text-gray-900">Validación automática:</strong> productos autorizados, dosis, plazos de seguridad</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-700"><strong class="text-gray-900">Visión global</strong> de todas tus explotaciones en un panel</span>
            </li>
          </ul>

          <!-- CTA -->
          <div class="mt-12">
            <a
              href={calendlyUrl}
              target="_blank"
              rel="noopener noreferrer"
              id="cta-demo"
              class="group inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-primary-600 to-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-900/30 transition-all duration-300 hover:shadow-xl hover:shadow-primary-900/40 hover:-translate-y-0.5"
            >
              <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              Reservar demo
              <svg class="ml-2 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>

          <p class="mt-4 text-sm text-gray-400">Menos de 30 min &middot; Sin compromiso &middot; Online</p>
        </div>
      </div>
    </section>

    <!-- Footer mínimo -->
    <footer class="py-6 px-4 sm:px-6 lg:px-8 text-center">
      <div class="flex items-center justify-center gap-4 text-sm text-gray-400">
        <a href="/privacidad" class="hover:text-gray-600 transition-colors">Privacidad</a>
        <span>&middot;</span>
        <a href="/terminos" class="hover:text-gray-600 transition-colors">Términos</a>
        <span>&middot;</span>
        <a href="/cookies" class="hover:text-gray-600 transition-colors">Cookies</a>
      </div>
    </footer>
  </main>

  <script>
    const variants: Record<string, { headline: string; accent: string; subtitle: string }> = {
      a: {
        headline: 'Registra tratamientos de todas tus explotaciones ',
        accent: 'sin perder la cabeza',
        subtitle: 'Crisopa es el cuaderno de campo pensado para asesores que gestionan muchas explotaciones. Registro en masa, validación automática, cero horas perdidas.',
      },
      b: {
        headline: 'Deja de perder horas ',
        accent: 'registrando tratamientos uno a uno',
        subtitle: 'Crisopa está pensado para asesores que gestionan en volumen. De 10 a 200 explotaciones, en minutos en vez de horas.',
      },
      c: {
        headline: 'De 10 a 200 explotaciones. ',
        accent: 'En minutos, no en horas',
        subtitle: 'El cuaderno de campo que escala contigo. Registro en masa, validación automática y visión global de todas tus explotaciones.',
      },
    }

    document.addEventListener('astro:page-load', () => {
      const v = new URLSearchParams(window.location.search).get('v')
      const copy = v && variants[v] ? variants[v] : null

      // Cambiar copy si hay variante en la URL
      if (copy) {
        const h1 = document.getElementById('headline')
        const accent = document.getElementById('headline-accent')
        const subtitle = document.getElementById('subtitle')

        if (h1 && accent) {
          h1.childNodes.forEach(n => { if (n.nodeType === Node.TEXT_NODE) n.textContent = '' })
          h1.insertBefore(document.createTextNode(copy.headline), accent)
          accent.textContent = copy.accent
        }
        if (subtitle) subtitle.textContent = copy.subtitle
      }

      // Tracking: clic en CTA
      const cta = document.getElementById('cta-demo')
      cta?.addEventListener('click', () => {
        if ((window as any).va) {
          ;(window as any).va('event', {
            name: 'cta_demo_hola',
            data: { variant: v || 'a' },
          })
        }

        // Google Ads conversion (descomentar cuando se configure gtag)
        // gtag('event', 'conversion', { send_to: 'AW-XXXXXXXXX/XXXXXXXXXXXX' })
      })
    })
  </script>
</Layout>
